# ============================================================================
#  SPIDER IDENTIFIER — ENVIRONMENT VARIABLES (TEMPLATE)
# ----------------------------------------------------------------------------
#  Copy this file to ".env.local" and fill in the real values.
#  .env.local is git-ignored, so your keys are NEVER pushed to GitHub.
#  A full step-by-step guide for every key lives in .env.local and README.md.
# ============================================================================

# Public site URL (no trailing slash). Used for SEO, sitemap, OG tags.
NEXT_PUBLIC_SITE_URL=https://spideridentifier.com

# Supabase — Project URL + anon (public) key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — Service role key (SERVER ONLY — never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of emails allowed into /admin (e.g. you@site.com,team@site.com)
ADMIN_EMAILS=

# OPTIONAL — Resend API key to email you when a contact form is submitted.
# Leave blank to just store submissions in the database.
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=
