# ============================================================================
#  SPIDER IDENTIFIER — ENVIRONMENT VARIABLES (TEMPLATE)
# ----------------------------------------------------------------------------
#  Copy this file to ".env.local" and fill in the real values.
#  .env.local is git-ignored, so your keys are NEVER pushed to GitHub.
#  A full step-by-step guide for every key lives in .env.local and README.md.
# ============================================================================

# Public site URL (no trailing slash). Used for SEO, sitemap, OG tags.
NEXT_PUBLIC_SITE_URL=https://spideridentifier.com

# Supabase — Project URL + anon (public) key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — Service role key (SERVER ONLY — never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of emails allowed into /admin (e.g. you@site.com,team@site.com)
ADMIN_EMAILS=

# OPTIONAL — Resend API key to email you when a contact form is submitted.
# Leave blank to just store submissions in the database.
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=

# OPTIONAL — Anthropic Claude API key for LIVE AI spider identification.
# Without it, the identifier returns a demo result.
ANTHROPIC_API_KEY=

# OPTIONAL — Paddle billing (subscriptions). Without these, plan buttons link to signup.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
NEXT_PUBLIC_PADDLE_STARTER_PRICE_ID=
NEXT_PUBLIC_PADDLE_EXPLORER_PRICE_ID=
NEXT_PUBLIC_PADDLE_PRO_PRICE_ID=
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# OPTIONAL — Google Analytics 4. Get the "G-XXXXXXXXXX" Measurement ID from
# analytics.google.com → Admin → Data streams → your web stream.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# OPTIONAL — Google Search Console ownership token. Search Console → Settings
# → Ownership verification → HTML tag → copy ONLY the content="..." value.
GOOGLE_SITE_VERIFICATION=

# OPTIONAL — Admin analytics dashboard (GA4 + Search Console).
# 1. console.cloud.google.com → create project → enable "Google Analytics Data API"
#    and "Google Search Console API"
# 2. IAM & Admin → Service Accounts → Create → add a JSON key, copy values below
# 3. GA4: Admin → Property access management → add the service-account email (Viewer)
# 4. Search Console: Settings → Users and permissions → add the same email (Full)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GA4_PROPERTY_ID=
GSC_SITE_URL=

# OPTIONAL — Rank Tracker live SERP checks. Free key (250 searches/30d) from
# https://serpapi.com → Dashboard → API key. A second free account can be
# stacked via SERPAPI_KEY_BACKUP.
SERPAPI_KEY=
SERPAPI_KEY_BACKUP=
