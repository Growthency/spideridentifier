{
  "name": "spider-identifier",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered spider identification — identify any spider from a photo in seconds.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "convert:webp": "node scripts/convert-to-webp.mjs",
    "fetch:images": "node --experimental-strip-types scripts/fetch-images.mjs",
    "fetch:blog-images": "node scripts/fetch-blog-images.mjs",
    "seed": "node --experimental-strip-types --env-file=.env.local scripts/seed.mjs",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@paddle/paddle-js": "^1.6.4",
    "@paddle/paddle-node-sdk": "^3.8.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "next": "^15.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.4.49",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "wrangler": "^4.103.0"
  },
  "browserslist": [
    "Chrome >= 92",
    "Edge >= 92",
    "Firefox >= 91",
    "Safari >= 15.4",
    "iOS >= 15.4",
    "not dead"
  ]
}
